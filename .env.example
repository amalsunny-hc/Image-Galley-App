################################################################################
# IMAGE GALLERY - UNIFIED ENVIRONMENT CONFIGURATION
# ONE FILE FOR LOCAL, DOCKER, AND AWS
# 
# This single .env file works for all three deployment scenarios:
# - Local Development (SQLite)
# - Docker Local (MySQL) 
# - AWS Production (RDS + S3)
#
# SETUP:
# 1. Uncomment ONLY ONE DEPLOYMENT_MODE below
# 2. Generate SECRET_KEY: python3 -c "import secrets; print(secrets.token_hex(32))"
# 3. Configure variables for your chosen mode
# 4. Never commit this file to git (already in .gitignore)
#
################################################################################

# ==============================================================================
# STEP 1: CHOOSE YOUR DEPLOYMENT MODE
# ==============================================================================
# Uncomment ONE of these three options:

DEPLOYMENT_MODE=local
# DEPLOYMENT_MODE=docker
# DEPLOYMENT_MODE=aws

# ==============================================================================
# APPLICATION SETTINGS (All Modes)
# ==============================================================================
FLASK_APP=run.py
FLASK_ENV=development
FLASK_PORT=5000

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# For local dev: any string works
# For Docker/AWS: use generated string
SECRET_KEY=dev-secret-key-change-in-production

# Debug mode
# Set to True for development (local or docker)
# Set to False for production (AWS)
DEBUG=True

# File upload settings
MAX_FILE_SIZE=16777216
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp
UPLOAD_FOLDER=app/static/uploads

# ==============================================================================
# SCENARIO 1: LOCAL DEVELOPMENT (SQLite)
# ==============================================================================
# DEPLOYMENT_MODE=local above
# 
# NO additional configuration needed below
# App will use SQLite automatically
# Database file: image_gallery.db (created automatically)
#
# Commands:
#   python3 run.py
#   Visit: http://localhost:5000
# ==============================================================================

# ==============================================================================
# SCENARIO 2: DOCKER LOCAL (MySQL)
# ==============================================================================
# DEPLOYMENT_MODE=docker above
#
# Configure these MySQL variables for Docker:

# MySQL Root Password (Docker service)
MYSQL_ROOT_PASSWORD=root-password-123

# MySQL Database
MYSQL_DATABASE=image_gallery

# MySQL User for App
MYSQL_USER=gallery_user

# MySQL User Password
MYSQL_PASSWORD=user-password-123

# PHP MyAdmin Configuration (Docker)
PMA_HOST=mysql
PMA_USER=gallery_user
PMA_PASSWORD=user-password-123
PMA_ROOT_PASSWORD=root-password-123

# Commands:
#   docker-compose up -d
#   App: http://localhost:5000
#   phpMyAdmin: http://localhost:8080 (user: gallery_user / password: user-password-123)
# ==============================================================================

# ==============================================================================
# SCENARIO 3: AWS PRODUCTION (RDS + S3)
# ==============================================================================
# DEPLOYMENT_MODE=aws above
#
# Configure these AWS variables:

# AWS RDS MySQL Configuration
# Example endpoint: mydb.c9akciq32.us-east-1.rds.amazonaws.com
RDS_ENDPOINT=your-rds-endpoint.rds.amazonaws.com
RDS_DATABASE=image_gallery
RDS_USER=admin
RDS_PASSWORD=your-secure-rds-password
RDS_PORT=3306

# AWS S3 Configuration
# IAM role-based auth - NO AWS access keys needed!
# EC2 instance must have IAM role with S3 permissions
S3_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=us-east-1

# Commands:
#   gunicorn -w 4 -b 0.0.0.0:5000 run:app
#   Or: docker-compose -f docker-compose.aws.yml up -d
#   Visit: http://your-domain.com
# ==============================================================================

# ==============================================================================
# CONFIGURATION EXAMPLES
# ==============================================================================
#
# EXAMPLE 1 - LOCAL DEVELOPMENT:
# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT_MODE=local
# DEBUG=True
# FLASK_ENV=development
# SECRET_KEY=any-key-works-locally
# → Run: python3 run.py
#
# EXAMPLE 2 - DOCKER TEAM DEVELOPMENT:
# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT_MODE=docker
# DEBUG=True
# FLASK_ENV=development
# SECRET_KEY=your-generated-key
# MYSQL_ROOT_PASSWORD=Root@Pass123!
# MYSQL_USER=gallery_user
# MYSQL_PASSWORD=User@Pass123!
# MYSQL_DATABASE=image_gallery
# PMA_HOST=mysql
# PMA_USER=gallery_user
# PMA_PASSWORD=User@Pass123!
# PMA_ROOT_PASSWORD=Root@Pass123!
# → Run: docker-compose up -d
#
# EXAMPLE 3 - AWS PRODUCTION:
# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT_MODE=aws
# DEBUG=False
# FLASK_ENV=production
# SECRET_KEY=your-generated-key
# RDS_ENDPOINT=mydb.c9akciq32.us-east-1.rds.amazonaws.com
# RDS_USER=admin
# RDS_PASSWORD=Secure@RDS@Pass123!
# RDS_DATABASE=image_gallery
# S3_BUCKET_NAME=image-gallery-production
# AWS_REGION=us-east-1
# → Run: gunicorn -w 4 -b 0.0.0.0:5000 run:app
#
# ==============================================================================

# ==============================================================================
# HOW THE APP WORKS
# ==============================================================================
#
# The app (app/__init__.py) reads DEPLOYMENT_MODE and automatically:
#
# 1. If DEPLOYMENT_MODE=local:
#    → Uses SQLite (no other setup needed)
#    → Database: image_gallery.db
#
# 2. If DEPLOYMENT_MODE=docker AND MYSQL_USER exists:
#    → Uses Docker MySQL
#    → Connection: mysql+pymysql://user:pass@mysql:3306/db
#
# 3. If DEPLOYMENT_MODE=aws AND RDS_ENDPOINT exists:
#    → Uses AWS RDS MySQL
#    → Connection: mysql+pymysql://user:pass@endpoint:3306/db
#    → Uses IAM role for S3 access (no keys needed!)
#
# ==============================================================================

# ==============================================================================
# QUICK SETUP GUIDE
# ==============================================================================
#
# Step 1: Choose deployment mode
#   - Uncomment ONE: DEPLOYMENT_MODE=local|docker|aws
#
# Step 2: Generate SECRET_KEY (if not local)
#   python3 -c "import secrets; print(secrets.token_hex(32))"
#   Copy output to SECRET_KEY above
#
# Step 3: Configure your mode
#   - Local: No additional setup
#   - Docker: Set MYSQL_* variables
#   - AWS: Set RDS_* and S3_* variables
#
# Step 4: Run
#   - Local: python3 run.py
#   - Docker: docker-compose up -d
#   - AWS: gunicorn -w 4 -b 0.0.0.0:5000 run:app
#
# ==============================================================================

# ==============================================================================
# PASSWORD REQUIREMENTS
# ==============================================================================
#
# Local Development:
#   - Any password or even empty
#
# Docker Development:
#   - Recommended: 12+ characters
#   - Should include uppercase, lowercase, numbers
#   - Example: MyApp@Pass123
#
# AWS Production:
#   - REQUIRED: 16+ characters
#   - Must include: uppercase, lowercase, numbers, special chars
#   - Example: D$9mK#xL2pQ!w8vN$xRt
#   - Generate: openssl rand -base64 32
#
# ==============================================================================

# ==============================================================================
# SECURITY NOTES
# ==============================================================================
#
# ✓ This .env file is in .gitignore - never committed to git
# ✓ Never share this file with sensitive passwords
# ✓ For team: use separate .env files with different passwords
# ✓ For AWS: Uses IAM role (no access keys needed!)
# ✓ Always use strong passwords for Docker and AWS
#
# ==============================================================================

# ==============================================================================
# MIGRATION PATH
# ==============================================================================
#
# Want to upgrade from one mode to another?
# Just edit this file:
#
# Local → Docker:
#   1. Change DEPLOYMENT_MODE=local → docker
#   2. Add MYSQL_* variables
#   3. Run: docker-compose up -d
#
# Docker → AWS:
#   1. Change DEPLOYMENT_MODE=docker → aws
#   2. Remove MYSQL_* variables
#   3. Add RDS_* and S3_* variables
#   4. Deploy to EC2
#
# ==============================================================================

# ==============================================================================
# ENVIRONMENT-SPECIFIC SETTINGS
# ==============================================================================
#
# For local development: Keep DEBUG=True, FLASK_ENV=development
# For Docker testing: Set DEBUG=True or False (test both)
# For AWS production: Set DEBUG=False, FLASK_ENV=production
#
# ===============================================================================
