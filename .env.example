################################################################################
# IMAGE GALLERY - ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your own values
# NEVER commit your .env file to version control!
################################################################################

# ==============================================================================
# FLASK SETTINGS (Application Configuration)
# ==============================================================================
FLASK_APP=run.py
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=your-secret-key-generate-a-random-string-in-production

# ==============================================================================
# DEBUG & STORAGE MODE
# ==============================================================================
# DEBUG=True  → Uses LOCAL STORAGE (app/static/uploads/) - Development
# DEBUG=False → Uses AWS S3 STORAGE (with IAM role auth) - Production
# ==============================================================================
DEBUG=True

# ==============================================================================
# FILE UPLOAD SETTINGS
# ==============================================================================
MAX_FILE_SIZE=16777216
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp
UPLOAD_FOLDER=app/static/uploads

# ==============================================================================
# AWS S3 CONFIGURATION (Only used when DEBUG=False)
# ==============================================================================
# IAM role-based authentication - NO AWS keys needed!
# For development, leave these as placeholders
# For production, configure with your S3 bucket details
# ==============================================================================
S3_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=us-east-1

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# Choose based on your deployment environment:
# - SQLite for local development
# - MySQL for Docker/Production deployment
# ==============================================================================

# SQLite - For local development
DATABASE_URL=sqlite:///image_gallery.db

# MySQL - For Docker deployment
MYSQL_ROOT_PASSWORD=your-mysql-root-password
MYSQL_DATABASE=image_gallery
MYSQL_USER=gallery_user
MYSQL_PASSWORD=your-mysql-user-password

# ==============================================================================
# PHP MYADMIN CONFIGURATION (Docker only)
# ==============================================================================
# Used for database management in Docker environment
# ==============================================================================
PMA_HOST=mysql
PMA_USER=gallery_user
PMA_PASSWORD=your-mysql-user-password
PMA_ROOT_PASSWORD=your-mysql-root-password

################################################################################
# SETUP INSTRUCTIONS
################################################################################
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env with your actual values:
#    nano .env
#
# 3. For SECRET_KEY, generate a random string:
#    python3 -c "import secrets; print(secrets.token_hex(32))"
#
# 4. For MYSQL passwords, use strong passwords:
#    - At least 12 characters
#    - Mix of uppercase, lowercase, numbers, special chars
#
# 5. For S3, configure when deploying to production
#
# 6. IMPORTANT: Add .env to .gitignore (already done)
#    Never commit your .env file to git!
#
################################################################################

################################################################################
# ENVIRONMENT-SPECIFIC CONFIGURATIONS
################################################################################
#
# LOCAL DEVELOPMENT:
#   - DEBUG=True
#   - DATABASE_URL=sqlite:///image_gallery.db
#   - UPLOAD_FOLDER=app/static/uploads
#   - Run: python3 run.py
#
# DOCKER DEVELOPMENT:
#   - DEBUG=True (optional, for development)
#   - MYSQL_* configured
#   - Run: docker-compose up -d
#
# PRODUCTION (AWS):
#   - DEBUG=False
#   - DATABASE_URL=mysql://user:pass@host:3306/db
#   - S3_BUCKET_NAME=your-production-bucket
#   - Uses IAM role for S3 access (no keys needed)
#
################################################################################
